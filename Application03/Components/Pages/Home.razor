            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card bg-white h-100 border border-light-subtle rounded-4 p-4 shadow-sm hover-lift">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-cyan-soft text-cyan font-monospace">App Module 02</span>
                    <i class="bi bi-check-all text-muted fs-5"></i>
                </div>
                <h6 class="fw-bold text-dark mb-2">Form Data Annotations</h6>
