@page "/theme"
@rendermode InteractiveServer

<PageTitle>Theme Management - Application 07</PageTitle>

<div class="container mt-5" style="max-width: 500px;">
    <div class="premium-card p-4 shadow-lg text-center">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div class="text-start">
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">Theme Engine</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Application 07</span>
            </div>
            <span class="telemetry-badge">Persistence Layer</span>
        </div>

        <div class="text-start mb-4">
            <h5 class="fw-bold mb-2">Persistent Configuration</h5>
            <p class="text-muted small">
                Clicking the button below invokes client-side JavaScript Interop pipelines to alter HTML attributes while keeping values cached inside your local browser container workspace.
            </p>
        </div>

        <div class="p-3 bg-light rounded-3 d-flex justify-content-center align-items-center border mb-3" style="border-color: var(--glass-border) !important; background: rgba(0,0,0,0.02) !important;">
            <ThemeToggle />
        </div>

        <div class="text-center mt-3">
            <span class="small text-muted">Try reloading the browser page to test persistence!</span>
        </div>

    </div>
</div>