@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="d-flex align-items-center justify-content-center w-100">
    <button class="btn btn-premium-primary px-4 py-2.5 d-flex align-items-center justify-content-center gap-2"
            style="border-radius: 10px; font-size: 0.95rem; min-width: 210px;"
            @onclick="ToggleThemeAsync">
        @if (isDarkMode)
        {
            <i class="bi bi-sun-fill text-warning" style="font-size: 1.1rem;"></i>
            <span>Switch to Light Mode</span>
        }
        else
        {
            <i class="bi bi-moon-stars-fill" style="font-size: 1.1rem; color: #a5b4fc;"></i>
            <span>Switch to Dark Mode</span>
        }
    </button>
</div>

@code {
    private bool isDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var currentTheme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "app-theme");
                isDarkMode = (currentTheme == "dark");
                await ApplyThemeToDocumentAsync();
                StateHasChanged();
            }
            catch
            {
                // Gracefully catch prerendering check failures
            }
        }
    }

    private async Task ToggleThemeAsync()
    {
        isDarkMode = !isDarkMode;
        string themeValue = isDarkMode ? "dark" : "light";
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "app-theme", themeValue);
        await ApplyThemeToDocumentAsync();
    }

    private async Task ApplyThemeToDocumentAsync()
    {
        string themeValue = isDarkMode ? "dark" : "light";
        await JSRuntime.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", themeValue);
    }
}