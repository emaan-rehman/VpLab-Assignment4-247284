@page "/settings"
@rendermode InteractiveServer
@inject NotificationConfig Config
<PageTitle>Settings - Application 06</PageTitle>
<div class="container mt-5" style="max-width: 500px;">
    <div class="premium-card p-4 shadow-lg">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div>
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">Notification Settings</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Configuration Panel</span>
            </div>
            <span class="telemetry-badge">Config Engine</span>
        </div>
        <div class="mb-4 text-start">
            <label class="form-label text-muted small fw-bold text-uppercase tracking-wider">Default Display Limit</label>
            <input type="number" class="form-control form-premium text-main" min="1" max="10" @bind="Config.DefaultNumberOfNotifications" />
            <div class="form-text small text-muted">Defines default items generated per diagnostics fetch lifecycle loop.</div>
        </div>
        <div class="mb-4 text-start">
            <label class="form-label text-muted small fw-bold text-uppercase tracking-wider">Interface Display Layout</label>
            <select class="form-select form-premium text-main" @bind="Config.NotificationStyle">
                <option value="Compact">Compact Mode (Title & Time Only)</option>
                <option value="Detailed">Detailed Mode (Full System Logs)</option>
            </select>
        </div>
        <div class="pt-2 border-top" style="border-color: var(--glass-border) !important;">
            <a href="/notifications" class="btn btn-premium-primary w-100 py-2 text-uppercase tracking-wider">
                Apply & View Feed
            </a>
        </div>
    </div>
</div>