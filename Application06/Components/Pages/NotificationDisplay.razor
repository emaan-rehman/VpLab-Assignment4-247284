@page "/notifications"
@rendermode InteractiveServer
@inject NotificationService NotifyService
@inject NotificationConfig Config

<PageTitle>Notifications - Application 06</PageTitle>

<div class="container mt-5" style="max-width: 550px;">
    <div class="premium-card p-4 shadow-lg">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div>
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">System Notifications</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Live System Telemetry Feed</span>
            </div>
            <span class="telemetry-badge fw-bold">
                Style: @Config.NotificationStyle
            </span>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-outline-secondary btn-sm px-3 py-1 text-uppercase tracking-wider"
                    style="font-size: 0.75rem; border-radius: 6px;"
                    @onclick="FetchLatestDataAsync">
                Refresh Feed
            </button>
            <a href="/settings" class="small text-indigo text-decoration-none fw-semibold">
                ⚙ Edit Configuration Settings
            </a>
        </div>

        <div class="notification-stream mt-2">
            @if (alerts == null)
            {
                <div class="text-center py-4 text-muted small tracking-wider text-uppercase">
                    Initializing safe network diagnostic connection streams...
                </div>
            }
            else if (alerts.Count == 0)
            {
                <div class="p-4 text-center bg-indigo-soft text-indigo rounded-3 border" style="border-style: dashed !important;">
                    No notification messages generated in this diagnostic batch scope.
                </div>
            }
            else
            {
                @foreach (var item in alerts)
                {
                    @if (Config.NotificationStyle == "Detailed")
                    {
                        <div class="p-3 mb-3 text-start bg-white"
                             style="border: 1px solid var(--glass-border); border-left: 4px solid #6366f1; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h6 class="text-main fw-bold m-0 text-indigo">@item.Title</h6>
                                <span class="text-muted small" style="font-size: 0.7rem;">@item.Timestamp.ToString("hh:mm tt")</span>
                            </div>
                            <p class="text-main small m-0 mb-2" style="line-height: 1.4;">@item.Description</p>
                            <span class="badge bg-light text-muted border px-2 py-1 font-monospace" style="font-size: 0.65rem;">
                                NODE_ID_REF_X: #@item.Id
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 mb-2 bg-indigo-soft text-main"
                             style="border-radius: 8px; border-left: 3px solid #06b6d4;">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-main" style="font-size: 0.9rem;">● @item.Title</span>
                            </div>
                            <span class="text-muted font-monospace" style="font-size: 0.75rem;">@item.Timestamp.ToString("hh:mm")</span>
                        </div>
                    }
                }
            }
        </div>

    </div>
</div>

@code {
    private List<NotificationItem>? alerts;

    protected override async Task OnInitializedAsync()
    {
        await FetchLatestDataAsync();
    }

    private async Task FetchLatestDataAsync()
    {
        // Fetches notifications using the injected configuration defaults automatically
        alerts = await NotifyService.GetNotificationsAsync();
    }
}