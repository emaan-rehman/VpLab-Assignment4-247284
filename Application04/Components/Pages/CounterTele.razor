@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter - Application 04</PageTitle>

<div class="container mt-5" style="max-width: 500px;">
    <div class="premium-card p-4 shadow-lg text-center">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div class="text-start">
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">Interactive Counter</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Application 04</span>
            </div>
            <span class="telemetry-badge">
                Live Status
            </span>
        </div>
        <div class="p-4 mb-4 bg-indigo-soft text-indigo rounded-3">
            <p class="text-uppercase tracking-wider small fw-bold text-muted mb-1">Current Count</p>
            <h1 class="display-3 fw-extrabold my-2 gradient-header">
                @clickCount
            </h1>
        </div>

        <div class="mb-4">
            <button class="btn btn-premium-primary w-100 py-3 text-uppercase tracking-wider" @onclick="IncrementCounter">
                Click to Increment (+1)
            </button>
        </div>

        <div class="p-3 border text-start rounded-3" style="background: rgba(0, 0, 0, 0.01); border-color: var(--glass-border) !important;">
            <div class="row align-items-center">
                <div class="col-7">
                    <label class="form-label text-muted small fw-bold text-uppercase tracking-wider mb-0">
                        Adjust Manually
                    </label>
                </div>
                <div class="col-5">
                    <input type="number"
                           class="form-control form-premium text-main text-center fw-bold"
                           @bind="clickCount"
                           @bind:event="oninput" />
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-outline-secondary btn-sm w-50 py-2 text-uppercase tracking-wider" style="border-radius: 8px;" @onclick="ResetCounter">
                Reset
            </button>
            <button class="btn btn-premium-danger btn-sm w-50 py-2 text-uppercase tracking-wider" style="border-radius: 8px;" @onclick="MultiplyCounter">
                Multiply (x2)
            </button>
        </div>

    </div>
</div>

@code {
    private int clickCount = 0;
    private void IncrementCounter()
    {
        clickCount++;
    }
    private void ResetCounter()
    {
        clickCount = 0;
    }
    private void MultiplyCounter()
    {
        clickCount *= 2;
    }
}