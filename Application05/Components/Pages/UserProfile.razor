@page "/profile"
@rendermode InteractiveServer
@inject AuthenticationStateService AuthState
@implements IDisposable

<PageTitle>User Profile - Application 05</PageTitle>

<div class="container mt-5" style="max-width: 500px;">
    <div class="premium-card p-4 shadow-lg text-center">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div class="text-start">
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">User Dashboard</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Profile Status</span>
            </div>

            <div class="avatar-circle text-indigo-light bg-indigo fw-bold" style="width: 38px; height: 38px; font-size: 1.1rem;">
                @(AuthState.IsAuthenticated && !string.IsNullOrEmpty(AuthState.Username)
                    ? AuthState.Username.Trim().Substring(0, 1).ToUpper()
                    : "?")
            </div>
        </div>

        @if (AuthState.IsAuthenticated)
        {
            <div class="p-4 bg-indigo-soft text-indigo rounded-3 border text-start mb-4" style="border-color: rgba(99, 102, 241, 0.2) !important;">
                <h3 class="fw-extrabold mb-2 text-indigo">Welcome Back, @AuthState.Username!</h3>
                <p class="text-muted small mb-0">Your profile metrics are synchronized via the centralized multi-component singleton layer.</p>
            </div>

            <button class="btn btn-premium-danger w-100 py-2 text-uppercase tracking-wider" @onclick="ForceLogout">
                Terminate Active Session
            </button>
        }
        else
        {
            <div class="p-4 rounded-3 border mb-4 text-muted bg-light" style="border-style: dashed !important; border-width: 2px !important; border-color: var(--glass-border) !important;">
                <h5 class="fw-bold text-secondary mb-2">Access Denied</h5>
                <p class="small mb-0">No valid credentials found in shared state memory. Please authenticate to view data metrics.</p>
            </div>

            <a href="/login" class="btn btn-premium-primary w-100 py-2 text-uppercase tracking-wider">
                Go to Sign In
            </a>
        }
    </div>
</div>
@code {
    private void ForceLogout() {
        AuthState.LogOut();
    }
    protected override void OnInitialized()  {
        AuthState.OnStateChanged += StateHasChanged;
    }
    public void Dispose(){
        AuthState.OnStateChanged -= StateHasChanged;
    }
}