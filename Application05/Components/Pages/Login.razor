@page "/login"
@rendermode InteractiveServer
@inject AuthenticationStateService AuthState
@implements IDisposable

<PageTitle>Login Gate - Application 05</PageTitle>

<div class="container mt-5" style="max-width: 500px;">
    <div class="premium-card p-4 shadow-lg text-center">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--glass-border) !important;">
            <div class="text-start">
                <h3 class="gradient-header m-0 fw-extrabold tracking-tight">System Access</h3>
                <span class="brand-subtitle text-uppercase tracking-wider">Authentication Control</span>
            </div>
            <span class="telemetry-badge">
                @(AuthState.IsAuthenticated ? "Authorized" : "Locked")
            </span>
        </div>

        @if (!AuthState.IsAuthenticated)
        {
            <div class="text-start mb-4">
                <label class="form-label text-muted small fw-bold text-uppercase tracking-wider">Username</label>
                <input type="text"
                       class="form-control form-premium text-main"
                       placeholder="Enter your name..."
                       @bind="inputUsername"
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress" />

                @if (string.IsNullOrWhiteSpace(inputUsername))
                {
                    <div class="form-text text-danger small mt-1">Username parameter cannot be empty.</div>
                }
            </div>

            <button class="btn btn-premium-primary w-100 py-2 text-uppercase tracking-wider"
                    @onclick="HandleLogin"
                    disabled="@string.IsNullOrWhiteSpace(inputUsername)">
                Sign In
            </button>
        }
        else
        {
            <div class="p-4 bg-indigo-soft text-indigo rounded-3 mb-4">
                <p class="mb-1 text-muted small text-uppercase fw-bold">Active User Identity</p>
                <h4 class="fw-extrabold m-0 text-main">@AuthState.Username</h4>
                <div class="mt-2 text-success small">✓ Secure session pipeline established</div>
            </div>

            <div class="d-flex gap-2">
                <a href="/profile" class="btn btn-outline-secondary w-50 py-2 text-uppercase tracking-wider" style="font-size: 0.85rem;">
                    Go to Dashboard
                </a>
                <button class="btn btn-premium-danger w-50 py-2 text-uppercase tracking-wider" style="font-size: 0.85rem;" @onclick="HandleLogout">
                    Sign Out
                </button>
            </div>
        }

    </div>
</div>

@code {
    private string inputUsername = string.Empty;

    private void HandleLogin()
    {
        if (!string.IsNullOrWhiteSpace(inputUsername))
        {
            AuthState.LogIn(inputUsername);
            inputUsername = string.Empty;
        }
    }
    private void HandleLogout()
    {
        AuthState.LogOut();
    }
    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            HandleLogin();
        }
    }
    protected override void OnInitialized()
    {
        AuthState.OnStateChanged += StateHasChanged;
    }
    public void Dispose()
    {
        AuthState.OnStateChanged -= StateHasChanged;
    }
}