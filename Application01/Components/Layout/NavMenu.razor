@rendermode InteractiveServer

<div class="premium-sidebar d-flex flex-column h-100 p-4">
    <div class="brand-container d-flex align-items-center gap-3 mb-4 pb-3 border-bottom border-secondary-subtle border-opacity-10">
        <div class="brand-logo-wrapper">
            <div class="logo-ambient-glow"></div>
            <i class="bi bi-activity logo-icon-spin"></i>
        </div>
        <div class="brand-text-block">
            <h5 class="m-0 brand-title">LAB PORTAL</h5>
            <span class="brand-subtitle font-monospace">CORE ENGINE V4.0</span>
        </div>
    </div>

    <div class="nav-links-wrapper flex-grow-1 d-flex flex-column gap-2">
        <NavLink class="nav-item-link" href="" Match="NavLinkMatch.All">
            <i class="bi bi-grid-1x2-fill icon-left"></i>
            <span class="link-text">Dashboard Terminal</span>
        </NavLink>

        <NavLink class="nav-item-link" href="greeting">
            <i class="bi bi-person-badge-fill icon-left"></i>
            <span class="link-text">Personalization Hub</span>
            <span class="badge bg-indigo ms-auto nav-pill-badge">App 01</span>
        </NavLink>
    </div>

    <div class="sidebar-footer pt-3 mt-auto border-top border-secondary-subtle border-opacity-10">
        <div class="d-flex align-items-center gap-3">
            <div class="avatar-circle">
                <i class="bi bi-person-fill text-white"></i>
            </div>
            <div class="overflow-hidden">
                <p class="m-0 text-white fw-semibold small text-truncate">Emaan Rehman</p>
                <small class="text-muted d-block font-monospace" style="font-size: 0.65rem;">ID: 247284-AU</small>
            </div>
        </div>
    </div>
</div>