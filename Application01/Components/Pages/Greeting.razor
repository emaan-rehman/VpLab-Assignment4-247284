@page "/greeting"
@rendermode InteractiveServer

<PageTitle>Application 1 - Data Binding</PageTitle>

<div class="container mt-4">
    <h3>Application 1: Interactive Greeting</h3>
    <hr />

    <div class="mb-3 col-md-6">
        <label for="nameInput" class="form-label">Enter your name:</label>
        <input type="text" id="nameInput" class="form-control" @bind="userName" placeholder="Type a name..." />
    </div>

    <div class="alert alert-primary mt-3 col-md-6" role="alert">
        <strong>Greeting:</strong> Hello, @(string.IsNullOrWhiteSpace(userName) ? "Guest" : userName)! Welcome to Visual Programming.
    </div>
</div>

@code {
    // The component property acting as the source of truth
    private string userName { get; set; } = string.Empty;
}